# AdInteract — environment variables
# Copy to .env.local and fill in. NEVER commit real values (.env* is gitignored).
# See docs/security.md for which are server-only.

# --- Supabase ---
# Public (safe in client bundle — RLS enforces access):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — full DB power, bypasses RLS. MUST NOT reach the client bundle.
# Used only on the serving read and the Stripe webhook write paths.
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
# Public (client checkout):
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Server-only:
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe Price IDs (create the products/prices in the Stripe dashboard):
STRIPE_PRICE_SINGLE_WEEKLY=     # $2 / week, single template
STRIPE_PRICE_SINGLE_MONTHLY=    # $5 / month, single template
STRIPE_PRICE_ULTIMATE_MONTHLY=  # $30 / month, all-access

# --- App ---
# Public base URL (used for VAST tag URLs, Stripe redirects, signed-URL audience):
NEXT_PUBLIC_SITE_URL=http://localhost:3000
